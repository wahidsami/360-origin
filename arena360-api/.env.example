# Database – on VPS use your PostgreSQL host, user, password, and DB name
# The app expects a database named "arena360" (create it in pgAdmin or psql if missing)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/arena360?schema=public"

# JWT – generate a strong random string for production (e.g. openssl rand -hex 64)
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_EXPIRES_IN="1d"

# CORS – set to your frontend URL(s), comma-separated
ALLOWED_ORIGINS="https://your-domain.com"

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=

# OpenAI (optional, for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# PDF export runtime (Puppeteer / Chromium)
# If you use the provided Dockerfile, these defaults are already configured in the image.
PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium-browser"
PUPPETEER_DISABLE_SANDBOX="true"

# S3 / MinIO – on VPS use your object storage endpoint and credentials
S3_ENDPOINT="https://s3.your-region.amazonaws.com"
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET="arena360-assets"
S3_REGION="us-east-1"
